rules_version = '2';

// Medicar — Storage. Por ahora SOLO fotos de perfil.
service firebase.storage {
  match /b/{bucket}/o {

    // Admin: el rol vive en Firestore (usuarios/{uid}.roles). Storage lo lee con firestore.get().
    function esAdminStorage() {
      return request.auth != null
        && firestore.get(/databases/(default)/documents/usuarios/$(request.auth.uid)).data.get('roles', []).hasAny(['admin', 'superadmin']);
    }

    // feed/{docId}/... (PWA-2c): imágenes del feed "Para vos".
    // Lectura PÚBLICA (el socio ve la foto en la tarjeta). Escritura/borrado: SOLO admin, imagen, < 3 MB.
    match /feed/{docId}/{archivo=**} {
      allow read:   if true;
      allow write:  if esAdminStorage()
                       && request.resource.size < 3 * 1024 * 1024
                       && request.resource.contentType.matches('image/.*');
      allow delete: if esAdminStorage();
    }

    // Fotos de perfil: perfiles/{uid}/...
    // Escritura: SOLO el dueño (su propio uid), imagen, <3 MB.
    // Lectura: cualquier usuario autenticado -> los avatares se muestran en toda la app
    //          (ej. el médico asignado a un episodio, el personal en el panel). No son
    //          datos sensibles; el padrón clínico vive en Firestore con sus propias reglas.
    match /perfiles/{uid}/{archivo=**} {
      allow read:   if request.auth != null;
      allow write:  if request.auth != null
                       && request.auth.uid == uid
                       && request.resource.size < 3 * 1024 * 1024
                       && request.resource.contentType.matches('image/.*');
      allow delete: if request.auth != null && request.auth.uid == uid;
    }

    // Todo lo demas: cerrado.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
