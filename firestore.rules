rules_version = '2';

// Medicar — Estructura medica.
//   Etapa 1: Auth + rol.
//   Etapa 2 (despacho + atencion): contador atomico, episodio clinico.
//   Permisos por rol (estricto + actor): cada accion atada a su rol;
//   la clinica/cierre solo la hace el medico ASIGNADO al episodio.
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // Rol "espejo" (por defecto) del usuario — usuarios/{uid}.rol. Se conserva por compat.
    function rolActual() {
      return get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.rol;
    }

    // Multi-rol (Tramo 1): lista de roles del usuario. usuarios/{uid}.roles[] si existe;
    // si no, fallback al campo rol viejo como lista de uno (ventana de compat de migracion).
    function rolesActual() {
      return get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.get('roles', [rolActual()]);
    }

    // El usuario tiene ALGUNO de los roles pedidos (caps-union). Fail-closed: exige doc.
    function tieneRol(roles) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/usuarios/$(request.auth.uid))
        && rolesActual().hasAny(roles);
    }

    function isAdmin() {
      return tieneRol(['admin']);
    }

    function esDespachante() {
      return tieneRol(['despachante']);
    }

    function esMedico() {
      return tieneRol(['medico']);
    }

    // Superadmin / director medico: rol maximo, poder total sin restriccion.
    function esSuperadmin() {
      return tieneRol(['superadmin']);
    }

    // Roles operativos (lectura compartida del tablero). Incluye superadmin.
    function esOperativo() {
      return tieneRol(['despachante', 'medico', 'admin', 'superadmin']);
    }

    // Roles INTERNOS: usuario con AL MENOS un rol no-afiliado (incluye chofer). Un afiliado
    // puro (roles:['afiliado']) queda fuera; un multi-rol medico+afiliado ES interno (staff).
    // Para lectura del catalogo comercial (prestaciones/planes) por todo el personal. Fail-closed.
    function esInterno() {
      return tieneRol(['superadmin', 'admin', 'despachante', 'medico', 'chofer']);
    }

    // Claves que cambia este write (set de campos tocados).
    function tocadas() {
      return request.resource.data.diff(resource.data).affectedKeys();
    }

    // personaId vinculado a la cuenta actual (app del socio, Etapa 23). Vive en usuarios/{uid}.personaId.
    // SOLO se invoca en las ramas de lectura del AFILIADO (detras de un esInterno() que cortocircuita
    // para el personal), asi no suma un get() a los operativos. Sin vinculo -> null (no matchea ningun
    // id, deniega). Los internos nunca lo evaluan.
    function miPersonaId() {
      return get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.get('personaId', null);
    }

    // Permisos granulares por persona (capa del centro de mando, ademas del rol).
    // Se guardan en usuarios/{uid}.permisos = { gestionar_moviles:bool, ... }.
    //  - superadmin: SIEMPRE true (cortocircuito; nunca depende del mapa).
    //  - resto: true SOLO si el doc existe y permisos[cap] == true.
    // FAIL-CLOSED: campo permisos ausente, cap ausente, o no-true => false.
    function tienePermiso(cap) {
      return esSuperadmin()
        || ( isSignedIn()
             && exists(/databases/$(database)/documents/usuarios/$(request.auth.uid))
             && get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.get('permisos', {}).get(cap, false) == true );
    }

    // usuarios/{uid}: cada quien lee su doc; admin lee toda la coleccion.
    // Escritura: alta/baja/cambios de rol -> solo superadmin (via panel / Admin SDK).
    // Mi perfil: cada usuario puede actualizar SOLO su propio nombre/fotoURL (nada mas).
    // Preferencia de recordatorio (app del socio, Etapa 24): el afiliado (cualquier dueno del doc)
    // actualiza SOLO su prefRecordatorio (dia de aviso del chequeo semanal) — rama aparte, hasOnly cerrado.
    // ANTI AUTO-EDICION (Etapa 29): NADIE (incluido superadmin) cambia 'rol' ni 'activo' de SU PROPIO doc
    // (guarda final). Un segundo superadmin administrando a OTRO queda intacto (uid != su uid).
    match /usuarios/{uid} {
      allow read:           if esSuperadmin() || (isSignedIn() && (request.auth.uid == uid || isAdmin()));
      allow create, delete: if esSuperadmin();
      allow update: if ( esSuperadmin()
                         || ( isSignedIn()
                              && request.auth.uid == uid
                              && tocadas().hasOnly(['nombre','fotoURL']) )
                         || ( isSignedIn()
                              && request.auth.uid == uid
                              && tocadas().hasOnly(['prefRecordatorio']) ) )
                       && !( request.auth.uid == uid && tocadas().hasAny(['rol','activo']) );
    }

    // pacientes/{id}: identidad + antecedentes (nucleo de la historia).
    // Alta y edicion: despachante o medico (ambos), o admin. Sin borrado desde cliente,
    // SALVO superadmin: lee, edita y borra sin restriccion.
    // NOTA (Etapa 29): create/update SIN validacion de shape es INTENCIONAL — simplicidad de carga en el
    // acto (el despacho no puede trabarse por forma). Revisar ante lanzamiento publico masivo (2026-07-07).
    match /pacientes/{id} {
      allow read:           if esOperativo();
      allow create, update: if esOperativo();
      allow delete:         if esSuperadmin();
    }

    // episodios/{id}: la atencion, cuelga del paciente.
    // Lectura: los 3 roles operativos.
    // Escritura: diferenciada por rol y por los campos que toca cada accion.
    match /episodios/{id} {
      // Lectura (Etapa 33 — acceso por necesidad, ROL-AWARE sobre el corazon del sistema):
      //  - despachante / admin / superadmin: ven TODO el tablero (lo operan).
      //  - MEDICO de guardia: SOLO sus episodios (medicoId==uid) + los OFRECIDOS (ofrecido==true) — no el
      //    tablero completo ni el archivo historico. Sus 2 queries de bandeja (where medicoId==uid /
      //    where ofrecido==true) son query-safe: cada una matchea una rama OR. Handoff TOMAR es un update
      //    ATOMICO (medicoId=uid + ofrecido=false en el mismo write) -> sin ventana de perdida de lectura.
      //  - CHOFER dueno: SOLO su propio episodio (choferId==uid), vista "mi despacho" (Bloque 3).
      allow read:   if esDespachante() || isAdmin() || esSuperadmin()
                       || (esMedico() && (resource.data.medicoId == request.auth.uid
                                          || resource.data.ofrecido == true))
                       || (isSignedIn() && resource.data.choferId == request.auth.uid);

      // Alta (fase despacho): solo despachante. Admin tambien. Superadmin sin restriccion.
      allow create: if esSuperadmin()
                       || ((esDespachante() || isAdmin())
                           && request.resource.data.estado == 'despacho');

      // Borrado: solo superadmin (el resto, nunca desde el cliente).
      allow delete: if esSuperadmin();

      // Update: superadmin y admin sin restriccion; el resto, segun la accion.
      // NOTA (Etapa 29): el update de ADMIN SIN whitelist (isAdmin() a secas) es INTENCIONAL — la operacion
      // necesita mano libre sobre el episodio (correcciones, reasignaciones). Revisar ante lanzamiento
      // publico masivo (2026-07-07). Los roles operativos NO-admin siguen con whitelists cerradas abajo.
      allow update: if esSuperadmin() || isAdmin() || (
        isSignedIn() && (
          // Asignar / reasignar recursos: solo despachante. Toca movil/medico/chofer.
          // Permitido en cualquier estado activo (incluye derivacion entre moviles
          // durante la atencion, p.ej. internacion). El nuevo medico pasa a ser el
          // asignado y es quien puede cerrar.
          (
            esDespachante()
            && tocadas().hasOnly(['movilId','movilNombre','medicoId','medicoNombre','choferId','choferNombre'])
            && resource.data.estado in ['despacho','en_camino','arribo','atencion']
          )
          // Avanzar estado: despachante o medico. Toca estado + el timestamp de esa transicion.
          // El salto despacho -> en_camino exige movil + medico ya asignados.
          // ORIGEN debe ser activo (no terminal): impide reabrir cerrado/cancelado por esta via.
          || (
            (esDespachante() || esMedico())
            && tocadas().hasOnly(['estado','transiciones'])
            && resource.data.estado in ['despacho','en_camino','arribo']
            && request.resource.data.estado in ['en_camino','arribo','atencion']
            && (
              request.resource.data.estado != 'en_camino'
              || (resource.data.movilId != null && resource.data.medicoId != null)
            )
          )
          // Chofer: avanza SU episodio. en_camino: solo estado+transiciones. arribo: ademas puede escribir el map 'arribo' (geo). Opcion B: sin medico. Requiere movil.
          || (
            request.auth.uid == resource.data.choferId
            && resource.data.movilId != null
            && (
              (
                resource.data.estado == 'despacho'
                && request.resource.data.estado == 'en_camino'
                && tocadas().hasOnly(['estado','transiciones'])
              )
              || (
                resource.data.estado == 'en_camino'
                && request.resource.data.estado == 'arribo'
                && tocadas().hasOnly(['estado','transiciones','arribo'])
              )
            )
          )
          // Clinica + cierre: solo el medico ASIGNADO a este episodio. Origen: atencion.
          // No se permite si el caso esta ofrecido (el cedente ya no lo trabaja).
          || (
            esMedico()
            && request.auth.uid == resource.data.medicoId
            && resource.data.estado == 'atencion'
            && resource.data.get('ofrecido', false) != true
            && tocadas().hasOnly(['estado','examen','desenlace','transiciones','cierres'])
            && request.resource.data.estado == 'cerrado'
          )
          // Cierre viejo por resolucion (compat): medico asignado. Origen: atencion.
          || (
            esMedico()
            && request.auth.uid == resource.data.medicoId
            && resource.data.estado == 'atencion'
            && resource.data.get('ofrecido', false) != true
            && tocadas().hasOnly(['estado','resolucion','transiciones','cierres'])
            && request.resource.data.estado == 'cerrado'
          )
          // Cancelar / anular: despachante o medico (p.ej. falsa alarma). Origen activo.
          || (
            (esDespachante() || esMedico())
            && resource.data.estado in ['despacho','en_camino','arribo','atencion']
            && tocadas().hasOnly(['estado','motivoCancelacion','transiciones'])
            && request.resource.data.estado == 'cancelado'
          )
          // Reapertura: de cerrado a atencion. Solo el medico ASIGNADO o admin.
          // Toca estado + reabierto (auditoria) + cierres (preserva el cierre previo).
          || (
            resource.data.estado == 'cerrado'
            && request.resource.data.estado == 'atencion'
            && tocadas().hasOnly(['estado','reabierto','cierres'])
            && (
              (esMedico() && request.auth.uid == resource.data.medicoId)
              || isAdmin()
            )
          )
          // Handoff - CEDER: el medico ASIGNADO ofrece su caso en atencion.
          // Marca ofrecido=true (+ registro). Sigue siendo su medicoId, pero ya no
          // puede cargar clinica/cerrar mientras este ofrecido (la regla de cierre
          // exige !ofrecido). El caso no cambia de dueno hasta que OTRO lo tome.
          || (
            esMedico()
            && request.auth.uid == resource.data.medicoId
            && resource.data.estado == 'atencion'
            && resource.data.get('ofrecido', false) != true
            && request.resource.data.get('ofrecido', false) == true
            && tocadas().hasOnly(['ofrecido','handoff'])
          )
          // Handoff - TOMAR: OTRO medico (distinto del asignado) toma un caso ofrecido.
          // Se pone a si mismo como medicoId y baja ofrecido=false (+ registro).
          // Aca SI cambia de dueno.
          || (
            esMedico()
            && resource.data.get('ofrecido', false) == true
            && resource.data.estado == 'atencion'
            && request.auth.uid != resource.data.medicoId
            && request.resource.data.medicoId == request.auth.uid
            && request.resource.data.ofrecido == false
            && tocadas().hasOnly(['medicoId','medicoNombre','ofrecido','handoff'])
          )
          // GEO (Etapa 22 + coords en Etapa 25): operativos (o el chofer dueno) escriben SOLO los campos geo
          // — whitelist cerrada. El barrio + coords (geoLat/geoLng) los resuelve el fire-and-forget del
          // despacho / el batch; no toca ningun otro campo.
          || (
            (esDespachante() || esMedico() || request.auth.uid == resource.data.choferId)
            && tocadas().hasOnly(['barrio','geoPrecision','geoResueltoEn','geoLat','geoLng'])
          )
        )
      );
    }

    // contadores/{id}: correlativo atomico (nroIncidente/FC-/RC-/series de socios).
    // C-1 (endurecimiento): antes era `write: if esOperativo()` — cualquier operativo podia PISAR o
    // retroceder un contador (el `allow delete: superadmin` era redundante bajo ese write amplio). Ahora
    // el update es SOLO incremento atomico +1, calco EXACTO de las 3 tx que existen (contadores/episodios
    // app:2029, contadores/facturas app:4364, series de socios asignarNumeroRaiz app:4546) y de la nueva
    // contadores/recibos. Ningun test toca contadores → sin regresion.
    match /contadores/{id} {
      allow read:   if esOperativo();
      // create: bootstrap de una serie nueva (ej. contadores/recibos la primera vez). ultimo numerico.
      allow create: if esOperativo()
                       && request.resource.data.keys().hasOnly(['ultimo','actualizadoEn'])
                       && request.resource.data.ultimo is number && request.resource.data.ultimo >= 1;
      // update: SOLO incremento +1 sobre el valor previo (0 si el doc no traia ultimo). Nunca retroceso ni pisada.
      allow update: if esOperativo()
                       && tocadas().hasOnly(['ultimo','actualizadoEn'])
                       && request.resource.data.ultimo == resource.data.get('ultimo', 0) + 1;
      allow delete: if esSuperadmin();
    }

    // staff_medico/{uid}: padron de medicos para asignacion (doc id = uid de Auth).
    // Solo datos de staff (nombre, activo) — sin afiliados, por eso es legible por operativos.
    // Alta/baja: admin (director medico) o superadmin. El uid sigue siendo la clave de las
    // reglas de episodios (medicoId == request.auth.uid), que no cambian.
    match /staff_medico/{uid} {
      allow read:           if esOperativo();
      allow create, delete: if isAdmin() || esSuperadmin();
      // Mi perfil: el propio médico puede actualizar SOLO su nombre en su ficha; nada mas.
      allow update: if isAdmin() || esSuperadmin()
                       || ( esMedico()
                            && request.auth.uid == uid
                            && tocadas().hasOnly(['nombre']) );
    }

    // moviles/{id}: flota. CASO DE PRUEBA de la capa de permisos granulares.
    //  - Lectura: roles operativos (todos ven la flota en el tablero).
    //  - Escritura (alta/edicion/baja): SOLO quien tenga gestionar_moviles
    //    (o superadmin, por cortocircuito en tienePermiso). Fail-closed.
    match /moviles/{id} {
      allow read:           if esOperativo();
      // Alta/baja y CRUD general de la flota: gestionar_moviles.
      allow create, delete: if esOperativo() && tienePermiso('gestionar_moviles');
      allow update: if esOperativo() && (
        // (a) CRUD general (editar campos del móvil): gestionar_moviles.
        tienePermiso('gestionar_moviles')
        // (b) DESPACHO: ocupar/liberar el móvil al asignar/reasignar desde el episodio.
        //     SOLO toca estado + episodioActivoId + actualizadoEn, y SOLO la transición
        //     disponible<->ocupado. Requiere despachar_episodios. Fail-closed.
        || (
          tienePermiso('despachar_episodios')
          && tocadas().hasOnly(['estado','episodioActivoId','actualizadoEn'])
          && resource.data.estado in ['disponible','ocupado']
          && request.resource.data.estado in ['disponible','ocupado']
        )
      );
    }

    // tipos_movil/{id}: catálogo de tipos de móvil (UTI, Traslado, ...). Mismo criterio que moviles:
    // lo ve cualquier operativo (para resolver el nombre del tipo en la flota), lo gestiona quien
    // tenga gestionar_moviles. Baja lógica vía campo activo (no se borra desde acá salvo superadmin
    // por el catch-all). Fail-closed igual que moviles.
    match /tipos_movil/{id} {
      allow read:                  if esOperativo();
      allow create, update, delete: if esOperativo() && tienePermiso('gestionar_moviles');
    }

    // guardias/{id}: cronograma de tripulacion (Bloque 1). Una guardia = UNA persona (chofer o medico)
    // en una ventana horaria, en un movil ('activa') o sin movil ('pasiva' = backup / auto propio).
    //  - Lectura: operativos (el chofer NO lee guardias todavia; eso es su propio bloque).
    //  - Escritura: gestionar_guardias. La regla valida PERMISO + FORMA + COHERENCIA LOCAL (mira solo
    //    el doc, sin queries). Los SOLAPES y medico-sin-chofer se validan en CLIENTE: las reglas no
    //    pueden hacer queries de rango entre docs.
    function guardiaFormaOK(d) {
      return d.rol in ['chofer','medico']
        && d.modalidad in ['activa','pasiva']
        && d.estado in ['programada','activa','cerrada']
        && (
             (d.modalidad == 'activa' && d.get('movilId', null) != null)
          || (d.modalidad == 'pasiva' && d.get('movilId', null) == null)
        );
    }
    match /guardias/{id} {
      allow read:           if esOperativo();
      allow create, update: if esOperativo()
                               && tienePermiso('gestionar_guardias')
                               && guardiaFormaOK(request.resource.data);
      allow delete:         if esOperativo() && tienePermiso('gestionar_guardias');
    }

    // agenda_turnos/{id} — franjas de disponibilidad de turnos (videollamada), Tramo Turnos T-A.1.
    // Las cargan los DIRECTORES (operativo + cap 'gestionar_agenda_turnos'). Baja = activa:false (sin delete).
    //  - Lectura: cualquier AUTENTICADO (el socio ve la disponibilidad; médico + horarios no son sensibles).
    //  - Escritura: operativo + cap + forma válida.
    //  - NOTA T-A.1: NO hay rama de escritura del socio sobre slotsTomados. La actualización por reserva/
    //    cancelación del socio se FRENÓ: no es expresable de forma segura en reglas puras (la regla no puede
    //    acoplarse al turno creado en la misma tx, y un diff acotado igual dejaría liberar/ocupar slots ajenos
    //    → doble-booking/DoS). El mecanismo de reserva (Cloud Function / per-slot doc / diff acotado) se
    //    decide antes de T-B. Ver reporte T-A.1.
    function agendaTurnoFormaOK(d) {
      return d.fecha is string
        && d.horaInicio is string && d.horaFin is string
        && d.horaInicio < d.horaFin
        && d.duracionSlotMin is int && d.duracionSlotMin > 0
        && d.medicoId is string && d.medicoId.size() > 0
        && d.activa is bool
        && d.slotsTomados is list;
    }
    match /agenda_turnos/{id} {
      allow read:           if isSignedIn();
      allow create, update: if esOperativo()
                               && tienePermiso('gestionar_agenda_turnos')
                               && agendaTurnoFormaOK(request.resource.data);
      allow delete:         if false;
    }

    // turnos/{id} — reserva de un turno de videollamada por el SOCIO. Calca el patrón crea-lo-suyo
    // (respuestas_cuestionario) + cancela-lo-suyo (prefRecordatorio). Cancelación = cambio de estado, nunca delete.
    //  - Create: interno, o el socio SU propio (personaId == miPersonaId, estado 'creado', whitelist exacta).
    //  - Read:   operativo (todos), o el socio SOLO los suyos.
    //  - Update: operativo, o el socio SOLO su propio y SOLO estado+canceladoEn con estado 'cancelado'.
    match /turnos/{id} {
      allow create: if esInterno()
                       || ( isSignedIn()
                            && request.resource.data.personaId == miPersonaId()
                            && request.resource.data.estado == 'creado'
                            && request.resource.data.keys().hasOnly(['fecha','hora','agendaId','personaId','nombreVista','medicoId','medicoNombre','estado','creadoEn']) );
      allow read:   if esOperativo()
                       || ( isSignedIn() && resource.data.personaId == miPersonaId() );
      allow update: if esOperativo()
                       || ( isSignedIn()
                            && resource.data.personaId == miPersonaId()
                            && tocadas().hasOnly(['estado','canceladoEn'])
                            && request.resource.data.estado == 'cancelado' );
      allow delete: if false;
    }

    // prestaciones/{id}: catalogo base de prestaciones (Emergencias, Urgencias, ...). Estructura 3 (Admin).
    //  - Lectura: cualquier rol INTERNO (no afiliado), incluido chofer — el personal lo consulta.
    //  - Escritura (alta/edicion; baja LOGICA via campo 'activo'): admin/superadmin o configurar_sistema.
    //    (tienePermiso ya cortocircuita superadmin a true.) Fail-closed.
    //  - Sin delete desde la app (baja logica). Superadmin conserva borrado por el catch-all.
    match /prestaciones/{id} {
      allow read:           if esInterno();
      allow create, update: if isAdmin() || tienePermiso('configurar_sistema');
    }

    // planes/{id}: catalogo comercial de planes + mapa coberturas{prestacionId:bool}. Estructura 3 (Admin).
    //  - Lectura: cualquier AUTENTICADO. El afiliado necesita leer el NOMBRE de su plan para la credencial
    //    de la app del socio (Etapa 23); el catalogo comercial no es dato sensible. isSignedIn() no hace
    //    get() (mas barato que esInterno) y cubre a todo el personal igual.
    //  - Escritura: admin/superadmin o configurar_sistema. Baja logica via 'activo', sin delete desde la app.
    match /planes/{id} {
      allow read:           if isSignedIn();
      allow create, update: if isAdmin() || tienePermiso('configurar_sistema');
      // historialPrecios (Tramo 5a): append-only. Lo escribe quien edita planes; no se actualiza ni borra.
      match /historialPrecios/{hid} {
        allow read:   if isSignedIn();
        allow create: if isAdmin() || tienePermiso('configurar_sistema');
        allow update, delete: if false;
      }
    }

    // personas/{id}: identidad del nucleo (Estructura 3, Admin). Si proviene de un paciente, id == pacienteId
    // (los episodios siguen apuntando por pacienteId, sin tocarse). Lleva los antecedentes CLINICOS.
    //  - Lectura: cualquier rol INTERNO (no afiliado). ADEMAS el AFILIADO lee SOLO su propia persona
    //    (id == su personaId) para la credencial de la app del socio (Etapa 23). Read-only.
    //  - Escritura (alta/edicion): admin/superadmin o gestionar_afiliados. Sin delete desde la app.
    // Lectura (Etapa 32 — acceso por necesidad): SOLO los lectores reales del padrón (admin/superadmin,
    // gestionar_afiliados = panel Afiliados, configurar_sistema = abonos/estadísticas) + el afiliado sobre
    // SU propia persona. Se CIERRA a médico/despachante/chofer: ninguno lee /personas en la app (recon E32).
    // planes_publicos/{id}: espejo público (curado) de planes para la LANDING (Tramo 5b). Lectura ANÓNIMA
    // (la landing es estática, sin login). Solo campos de marketing; el catálogo interno vive en /planes.
    match /planes_publicos/{id} {
      allow read:  if true;
      allow write: if isAdmin() || tienePermiso('configurar_sistema');
    }

    match /personas/{id} {
      allow read:           if isAdmin() || esSuperadmin()
                               || tienePermiso('gestionar_afiliados') || tienePermiso('configurar_sistema')
                               || (isSignedIn() && id == miPersonaId());
      allow create, update: if isAdmin() || tienePermiso('gestionar_afiliados');
    }

    // socios/{id}: padron de afiliados (Estructura 3, Admin). Apunta a personas via personaId; planId a planes.
    //  - Lectura (Etapa 32 — acceso por necesidad, ROL-AWARE): despachante (atribucion del despacho, L1292),
    //    admin/superadmin, gestionar_afiliados (panel Afiliados), configurar_sistema (abonos/estadisticas
    //    tambien leen socios), + el AFILIADO sobre su(s) propia(s) afiliacion(es) (para la credencial, E23;
    //    el != null evita el caso null==null). Se CIERRA a medico/chofer: no leen /socios en la app (recon E32).
    //  - Escritura: admin/superadmin o gestionar_afiliados. Baja LOGICA via 'activo', sin delete desde la app.

    // E-1: forma de socios.facturarA (destinatario de facturacion del titular). AUSENTE = persona (default, sin
    // migracion). Si esta: tipo en enum; si empresa -> empresaId y razonSocial string. Se valida en cada write del socio.
    function facturarAOk() {
      return !('facturarA' in request.resource.data)
        || ( request.resource.data.facturarA.get('tipo','') in ['persona','empresa']
             && ( request.resource.data.facturarA.get('tipo','') == 'persona'
                  || ( request.resource.data.facturarA.get('empresaId', null) is string
                       && request.resource.data.facturarA.get('razonSocial', null) is string ) ) );
    }

    // E-1: forma del convenio de una empresa. AUSENTE = sin convenio cargado todavia (E-2 lo carga).
    // modo en enum; fijo -> montoMensual number > 0; per_capita -> SIN montoMensual (el precio vive en el plan del socio).
    function convenioOk() {
      return !('convenio' in request.resource.data)
        || ( request.resource.data.convenio.keys().hasOnly(['modo','montoMensual'])
             && request.resource.data.convenio.get('modo','') in ['fijo','per_capita']
             && ( request.resource.data.convenio.get('modo','') == 'fijo'
                    ? ( request.resource.data.convenio.get('montoMensual', 0) is number
                        && request.resource.data.convenio.get('montoMensual', 0) > 0 )
                    : !('montoMensual' in request.resource.data.convenio) ) );
    }

    match /socios/{id} {
      allow read:           if esDespachante() || isAdmin() || esSuperadmin()
                               || tienePermiso('gestionar_afiliados') || tienePermiso('configurar_sistema')
                               || (isSignedIn() && miPersonaId() != null && resource.data.personaId == miPersonaId())
                               || (isSignedIn() && miPersonaId() != null && resource.data.titularPersonaId == miPersonaId()); // F2: el TITULAR lee sus dependientes (titularPersonaId denorm en F1)
      // E-1: gate intacto + validacion de forma de facturarA (solo cuando esta presente; no impone whitelist total).
      allow create, update: if (isAdmin() || tienePermiso('gestionar_afiliados')) && facturarAOk();
    }

    // empresas/{id}: raíz corporativa / área protegida (alta de socio) + convenio de cobro (E-1).
    // Gate (E-1, SEPARACION ESTRICTA): identidad (razonSocial/cuit/contacto/plan…) = admin/gestionar_afiliados
    // (alta inline) o configurar_sistema. CONVENIO (money) = SOLO admin/configurar_sistema (el contable, punto 4
    // de negocio). gestionar_afiliados NO puede crear ni tocar 'convenio'. hasOnly del shape completo; numeroConvenio/
    // tipo/creadoEn INMUTABLES (fuera del hasOnly de update). convenio validado por convenioOk().
    match /empresas/{id} {
      allow read:           if esDespachante() || isAdmin() || esSuperadmin()
                               || tienePermiso('gestionar_afiliados') || tienePermiso('configurar_sistema');
      // create: empGuardarNuevo + asignarNumeroRaiz (shape completo). Si trae 'convenio' -> exige gate contable.
      allow create: if (isAdmin() || tienePermiso('gestionar_afiliados') || tienePermiso('configurar_sistema'))
                       && ( !('convenio' in request.resource.data) || isAdmin() || tienePermiso('configurar_sistema') )
                       && request.resource.data.keys().hasOnly(['razonSocial','cuit','contacto','telefono','email','tipo','planIdDefault','activo','creadoEn','numeroConvenio','ultimoSufijo','convenio'])
                       && request.resource.data.keys().hasAll(['razonSocial','tipo','numeroConvenio'])
                       && request.resource.data.tipo in ['corporativo','area_protegida']
                       && request.resource.data.razonSocial is string
                       && convenioOk();
      // update: edicion del ABM (empGuardarEdit) + bump ultimoSufijo (asignarSufijo) + carga del convenio (E-2, contable).
      // Si 'convenio' esta entre los campos TOCADOS -> exige gate contable; gestionar_afiliados solo toca identidad.
      allow update: if (isAdmin() || tienePermiso('gestionar_afiliados') || tienePermiso('configurar_sistema'))
                       && ( !tocadas().hasAny(['convenio']) || isAdmin() || tienePermiso('configurar_sistema') )
                       && tocadas().hasOnly(['razonSocial','cuit','contacto','telefono','email','planIdDefault','activo','actualizadoEn','ultimoSufijo','convenio'])
                       && convenioOk();
    }

    // staff/{id}: padron laboral del personal (Estructura 3, Bloque 3). id == uid del usuario; apunta a
    // personas via personaId (== id). rol laboral medico|chofer|despachante|administrativo + matricula.
    //  - Lectura: rol INTERNO.
    //  - Escritura (alta/edicion): admin/superadmin o gestionar_personal. Baja LOGICA via 'activo', sin
    //    delete desde la app. NO altera las reglas de usuarios (cuentas) ni staff_medico (intactas).
    match /staff/{id} {
      allow read:           if esInterno();
      allow create, update: if isAdmin() || tienePermiso('gestionar_personal');
    }

    // tarifas/{id}: catalogo de tarifas de facturacion (Estructura 1, Contable). tipoCalculo fija|por_km,
    // precioBase, valorPorKm. Base para los motores de facturacion futuros.
    //  - Lectura: rol INTERNO (no afiliado).
    //  - Escritura (alta/edicion; baja LOGICA via 'activo'): admin/superadmin o configurar_sistema.
    //    Sin delete desde la app. Superadmin conserva borrado por el catch-all.
    match /tarifas/{id} {
      allow read:           if esInterno();
      allow create, update: if isAdmin() || tienePermiso('configurar_sistema');
    }

    // Gate financiero del carril (Contable): SOLO admin/superadmin o configurar_sistema (NO esInterno).
    function puedeFacturar() { return isAdmin() || tienePermiso('configurar_sistema'); }

    // Gate de COBRANZA (C-1, Contable-cobros): registra pagos. admin/superadmin o la cap gestionar_cobranza.
    // OJO — es un permiso DISTINTO de facturar: configurar_sistema NO hereda el cobro. Solo admin (isAdmin)
    // y superadmin (cortocircuita tienePermiso) entran por sus bypasses normales; el contable puro necesita
    // la cap explicita gestionar_cobranza. Calco exacto de puedeConfig()/puedeCobrar() del cliente (app).
    function puedeCobrar() { return isAdmin() || tienePermiso('gestionar_cobranza'); }

    // cargos/{id}: cargos de facturacion generados por episodio (Estructura 1, Contable). DATA FINANCIERA.
    // F-1 (blindaje): la integridad pasa de candado-en-cliente a reglas. Whitelists calcadas al motor real
    // (generarCargos/facCargoGuardar/facCargoAnular + facturaId de generarFacturas/facFacturaAnular).
    // INMUTABLE tras crear: episodioId/nroIncidente/socioId/personaId/tarifaId/precioSugerido (nunca en tocadas).
    // precioFinal editable SOLO mientras NO este facturado. NUNCA delete (anulacion logica).
    match /cargos/{id} {
      allow read:   if puedeFacturar();
      // create: shape exacto de generarCargos + forma barata (estado inicial + monto numerico >= 0).
      allow create: if puedeFacturar()
                       && request.resource.data.keys().hasOnly(['episodioId','nroIncidente','nroIncidenteFmt','personaId','socioId','pacNombre','regla','tarifaId','tarifaNombre','tipoCalculo','precioSugerido','valorPorKm','km','kmPendiente','precioFinal','motivoAjuste','estado','generadoEn','generadoPor'])
                       && request.resource.data.keys().hasAll(['episodioId','precioFinal','estado'])
                       && request.resource.data.estado == 'generado'
                       && request.resource.data.precioFinal is number && request.resource.data.precioFinal >= 0;
      // update — ajuste manual de monto (facCargoGuardar), SOLO si no facturado:
      allow update: if puedeFacturar() && resource.data.get('facturaId', null) == null
                       && tocadas().hasOnly(['km','kmPendiente','precioFinal','motivoAjuste','actualizadoEn'])
                       && request.resource.data.precioFinal is number && request.resource.data.precioFinal >= 0;
      // update — anulacion logica (facCargoAnular), SOLO si no facturado:
      allow update: if puedeFacturar() && resource.data.get('facturaId', null) == null
                       && tocadas().hasOnly(['estado','motivoAnulacion','anuladoEn','anuladoPor'])
                       && request.resource.data.estado == 'anulado';
      // update — asignar facturaId (generarFacturas), SOLO si aun no tiene (null -> string):
      allow update: if puedeFacturar() && resource.data.get('facturaId', null) == null
                       && tocadas().hasOnly(['facturaId']) && request.resource.data.facturaId is string;
      // update — liberar facturaId (facFacturaAnular), SOLO si lo tiene (campo removido):
      allow update: if puedeFacturar() && resource.data.get('facturaId', null) != null
                       && tocadas().hasOnly(['facturaId']) && !('facturaId' in request.resource.data);
    }

    // abonos/{id}: cuotas mensuales por socio (Estructura 1, Contable). DATA FINANCIERA. Mismo blindaje F-1.
    // INMUTABLE tras crear: periodo/socioId/personaId/planId/precioSugerido. precioFinal editable si NO facturado.
    match /abonos/{id} {
      allow read:   if puedeFacturar()
                       || (isSignedIn() && resource.data.personaId != null && resource.data.personaId == miPersonaId()); // F2: el AFILIADO lee SOLO sus abonos
      // create: shape exacto de generarAbonos (integrantesFacturados opcional) + forma barata.
      allow create: if puedeFacturar()
                       && request.resource.data.keys().hasOnly(['periodo','socioId','personaId','socioNombre','numeroAfiliado','planId','planNombre','precioSugerido','precioFinal','motivoAjuste','estado','generadoEn','generadoPor','integrantesFacturados'])
                       && request.resource.data.keys().hasAll(['periodo','socioId','planId','precioFinal','estado'])
                       && request.resource.data.estado == 'generado'
                       && request.resource.data.precioFinal is number && request.resource.data.precioFinal >= 0
                       && request.resource.data.periodo is string && request.resource.data.periodo.matches('^[0-9]{4}-[0-9]{2}$');
      // update — ajuste manual de monto (facAbonoGuardar), SOLO si no facturado:
      allow update: if puedeFacturar() && resource.data.get('facturaId', null) == null
                       && tocadas().hasOnly(['precioFinal','motivoAjuste','actualizadoEn'])
                       && request.resource.data.precioFinal is number && request.resource.data.precioFinal >= 0;
      // update — anulacion logica (facAbonoAnular), SOLO si no facturado:
      allow update: if puedeFacturar() && resource.data.get('facturaId', null) == null
                       && tocadas().hasOnly(['estado','motivoAnulacion','anuladoEn','anuladoPor'])
                       && request.resource.data.estado == 'anulado';
      // update — asignar facturaId (generarFacturas), SOLO si aun no tiene:
      allow update: if puedeFacturar() && resource.data.get('facturaId', null) == null
                       && tocadas().hasOnly(['facturaId']) && request.resource.data.facturaId is string;
      // update — liberar facturaId (facFacturaAnular), SOLO si lo tiene:
      allow update: if puedeFacturar() && resource.data.get('facturaId', null) != null
                       && tocadas().hasOnly(['facturaId']) && !('facturaId' in request.resource.data);
    }

    // facturas/{id}: cierre de Contable (Estructura 1). Agrupa abono + cargos por persona (items congelados).
    // DATA FINANCIERA. INMUTABLE tras emitir: items/total/personaId/socioId/periodo/numeroAfiliado.
    // Transiciones validas: emitida->pagada (facFacturaPagar) · emitida->anulada (facFacturaAnular). NUNCA delete.
    // F-2: nroComprobante (FC-AAAA-NNNNNN) REQUERIDO al emitir e INMUTABLE despues (no aparece en ningun update).
    match /facturas/{id} {
      allow read:   if puedeFacturar()
                       || (isSignedIn() && resource.data.get('personaId', null) != null && resource.data.get('personaId', null) == miPersonaId()); // F-3: el socio lee SOLO sus comprobantes (calco abonos F2). E-1: .get() -> las facturas de empresa (sin personaId) no rompen la evaluacion.
      // create: shape de generarFacturas + estado inicial 'emitida' + total >= 0 + nº comprobante. E-1: cliente POLIMORFICO.
      allow create: if puedeFacturar()
                       && request.resource.data.keys().hasOnly(['periodo','personaId','socioId','nombre','numeroAfiliado','items','total','estado','emitidaEn','emitidaPor','nroComprobante','clienteTipo','clienteId','clienteNombre'])
                       && request.resource.data.keys().hasAll(['periodo','items','total','estado','nroComprobante'])
                       && request.resource.data.estado == 'emitida'
                       && request.resource.data.total is number && request.resource.data.total >= 0
                       && request.resource.data.nroComprobante is string && request.resource.data.nroComprobante.matches('^FC-[0-9]{4}-[0-9]{6}$')
                       && request.resource.data.periodo is string && request.resource.data.periodo.matches('^[0-9]{4}-[0-9]{2}$')
                       // cliente polimorfico (espejo de pagos C-1): AUSENTE o 'persona' -> personaId presente, sin clienteId.
                       // 'empresa' -> clienteId + clienteNombre string, SIN personaId. Rechaza el hibrido (personaId + empresa).
                       && ( !('clienteTipo' in request.resource.data)
                            ? ('personaId' in request.resource.data && !('clienteId' in request.resource.data))
                            : ( request.resource.data.clienteTipo == 'persona'
                                  ? ('personaId' in request.resource.data && !('clienteId' in request.resource.data))
                                  : ( request.resource.data.clienteTipo == 'empresa'
                                        && request.resource.data.clienteId is string
                                        && request.resource.data.clienteNombre is string
                                        && !('personaId' in request.resource.data) ) ) );
      // update — flip DERIVADO emitida->pagada (C-1): acompaña Σpagos>=total. El facturador o el cobrador.
      // El "Σpagos>=total" es invariante cross-doc client-side (rol confiable), misma clase que facturaId de F-1:
      // la regla habilita la transicion; C-2 construye el flip. Antes era solo puedeFacturar(); se suma puedeCobrar().
      allow update: if (puedeFacturar() || puedeCobrar()) && resource.data.estado == 'emitida'
                       && tocadas().hasOnly(['estado','pagadaEn','pagadaPor'])
                       && request.resource.data.estado == 'pagada';
      // update — flip INVERSO pagada->emitida (C-1): al anular el ULTIMO pago la factura vuelve a emitida
      // (resuelve la contradiccion de app:4399). Mismos campos tocados. Facturador o cobrador.
      allow update: if (puedeFacturar() || puedeCobrar()) && resource.data.estado == 'pagada'
                       && tocadas().hasOnly(['estado','pagadaEn','pagadaPor'])
                       && request.resource.data.estado == 'emitida';
      // update — marca de migracion pagadaLegacy (C-1, la setea C-2 en las facturas pagadas PRE-cobranza):
      // no altera estado, solo estampa el flag para excluirlas del calculo de saldo. Idempotente (true).
      allow update: if puedeCobrar() && resource.data.estado == 'pagada'
                       && tocadas().hasOnly(['pagadaLegacy'])
                       && request.resource.data.pagadaLegacy == true;
      // update — anular, SOLO emitida->anulada (del facturador):
      allow update: if puedeFacturar() && resource.data.estado == 'emitida'
                       && tocadas().hasOnly(['estado','motivoAnulacion','anuladaEn','anuladaPor'])
                       && request.resource.data.estado == 'anulada';
    }

    // pagos/{id}: registro de COBRANZA (C-1, Contable-cobros). Un pago = 1 factura (semantica pago-por-factura,
    // parciales permitidos; saldo = factura.total - Σ pagos registrados, DERIVADO, no se guarda). pagadorId +
    // pagadorTipo polimorfico persona|empresa desde v1 (empresa sin superficie hasta F-4). Numero RC-AAAA-NNNNNN
    // (contador contadores/recibos, tx atomica pago+numero, calco de FC-). INMUTABLE: create + anulacion con motivo,
    // NUNCA edicion. Read: cobrador o facturador (el que emite ve los cobros); el socio NO lee pagos en v1.
    match /pagos/{id} {
      allow read:   if puedeCobrar() || puedeFacturar();
      // create: shape exacto + monto>0 + medio en enum + estado inicial 'registrado' + RC- bien formado + tipo en enum.
      allow create: if puedeCobrar()
                       && request.resource.data.keys().hasOnly(['pagadorId','pagadorTipo','facturaId','personaId','monto','fecha','medio','reciboNro','nota','estado','registradoEn','registradoPor'])
                       && request.resource.data.keys().hasAll(['pagadorId','pagadorTipo','facturaId','monto','fecha','medio','reciboNro','estado'])
                       && request.resource.data.pagadorTipo in ['persona','empresa']
                       && request.resource.data.facturaId is string
                       && request.resource.data.monto is number && request.resource.data.monto > 0
                       && request.resource.data.medio in ['efectivo','transferencia','deposito']
                       && request.resource.data.estado == 'registrado'
                       && request.resource.data.reciboNro is string && request.resource.data.reciboNro.matches('^RC-[0-9]{4}-[0-9]{6}$');
      // update — SOLO anulacion con motivo (registrado->anulado). Sin edicion de monto/medio/fecha (no hay otra rama).
      allow update: if puedeCobrar() && resource.data.estado == 'registrado'
                       && tocadas().hasOnly(['estado','motivoAnulacion','anuladoEn','anuladoPor'])
                       && request.resource.data.estado == 'anulado';
      // delete: nadie (default deny; los pagos se conservan como registro historico, la correccion es contra-asiento).
    }

    // leads/{id}: prospectos de captacion (Estructura 2, Marketing — Bloque 1). Datos personales de
    // interesados: NO se abre a todo el personal interno.
    //  - Lectura Y escritura: SOLO admin/superadmin o gestionar_afiliados (quien convierte da altas).
    //  - Descarte LOGICO via estado:'descartado'; conversion via estado:'convertido'; NUNCA delete desde la app.
    match /leads/{id} {
      allow read:           if isAdmin() || tienePermiso('gestionar_afiliados');
      allow create, update: if isAdmin() || tienePermiso('gestionar_afiliados');
    }

    // campanas/{id}: campanas de captacion (Estructura 2, Marketing — Bloque 3). Datos de marketing.
    //  - Lectura Y escritura: SOLO admin/superadmin o gestionar_afiliados (mismo gateo que leads).
    //  - Baja LOGICA via 'activo'; NUNCA delete desde la app.
    match /campanas/{id} {
      allow read:           if isAdmin() || tienePermiso('gestionar_afiliados');
      allow create, update: if isAdmin() || tienePermiso('gestionar_afiliados');
    }

    // auditoria/{id}: registro transversal INMUTABLE de mutaciones (fire-and-forget desde la app).
    //  - create: cualquier rol INTERNO (todo el personal que muta deja rastro).
    //  - read: solo admin/superadmin o configurar_sistema.
    //  - SIN update, SIN delete: inmutable (ni el superadmin edita/borra por esta regla; el catch-all
    //    del superadmin igual podria, es intencional como valvula, pero desde la app nunca se toca).
    match /auditoria/{id} {
      allow create: if esInterno();
      allow read:   if isAdmin() || tienePermiso('configurar_sistema');
    }

    // cuestionarios/{id}: plantillas del Nivel 1 de Monitoreo (cuestionario semanal). Eje transversal (Etapa 24).
    //  - Lectura: cualquier AUTENTICADO — el afiliado necesita leer el cuestionario activo para responderlo.
    //  - Escritura (alta/edicion; baja LOGICA via 'activo'): admin/superadmin o configurar_sistema. Sin delete.
    match /cuestionarios/{id} {
      allow read:           if isSignedIn();
      allow create, update: if isAdmin() || tienePermiso('configurar_sistema');
    }

    // respuestas_cuestionario/{id}: respuestas del socio al cuestionario semanal (Etapa 24). INMUTABLES.
    //  - create: el AFILIADO crea SOLO sobre SI MISMO (personaId == su personaId) y con la FORMA exacta
    //    (keys cerradas); tambien esInterno (carga asistida futura por el personal). Cuelga de personaId.
    //  - read: rol INTERNO (para el panel de Monitoreo) o el propio afiliado (sus respuestas).
    //  - SIN update, SIN delete: inmutables, como /auditoria.
    // ACCESO POR NECESIDAD (Etapa 31): el MÉDICO DE GUARDIA lee esta colección por la rama esInterno() (ya la
    // tenía) para ver las alertas — NO se agrega ninguna rama nueva. 'personaTelefono' (denorm) permite que el
    // médico LLAME sin leer /personas (lectura amplia que NO se le amplió aquí).
    match /respuestas_cuestionario/{id} {
      // hasOnly permite SUBCONJUNTOS: los cuestionarios sin WHO-5 / sin contacto validan igual (Etapa 26
      // suma who5/pedidoContacto/motivoContacto; Etapa 31 suma personaTelefono a la whitelist).
      allow create: if esInterno()
                       || ( isSignedIn()
                            && request.resource.data.personaId == miPersonaId()
                            && request.resource.data.keys().hasOnly(['cuestionarioId','cuestionarioNombre','personaId','personaNombre','personaTelefono','respuestas','who5','pedidoContacto','motivoContacto','creadoEn']) );
      allow read:   if esInterno() || (isSignedIn() && resource.data.personaId == miPersonaId());
    }

    // gestiones_contacto/{respuestaId}: atención de un "quiero que me contacten" (Etapa 26). La respuesta es
    // INMUTABLE; la gestión vive aparte. doc id = respuestaId (idempotente: una gestión por respuesta).
    //  - create: rol INTERNO (médico/admin marcan atendido). read: rol INTERNO. SIN update, SIN delete.
    match /gestiones_contacto/{respuestaId} {
      allow create: if esInterno();
      allow read:   if esInterno();
    }

    // sintomas_catalogo/{id}: catálogo de síntomas configurables del Nivel 2 (Etapa 30). El afiliado necesita
    // leer el catálogo activo para el auto-reporte.
    //  - read: cualquier AUTENTICADO. Escritura (alta/edición; baja LOGICA via 'activo'; banderaRoja/orden):
    //    admin/superadmin o configurar_sistema. Sin delete.
    match /sintomas_catalogo/{id} {
      allow read:           if isSignedIn();
      allow create, update: if isAdmin() || tienePermiso('configurar_sistema');
    }

    // reportes_sintomas/{id}: auto-reporte declarativo de síntomas del socio (Etapa 30, N2). INMUTABLE,
    // cuelga de personaId. Dispara alertas por el QUÉ (banderaRoja denorm). La atención vive en
    // gestiones_contacto/{reporteId} (mismo mecanismo que las respuestas).
    //  - create: el AFILIADO SOLO sobre SI MISMO (personaId == su personaId) con forma cerrada; o esInterno.
    //    (Etapa 31: 'personaTelefono' denorm sumado a la whitelist — el médico llama sin leer /personas.)
    //  - read: rol INTERNO (panel + MÉDICO de guardia, por esInterno — sin rama nueva) o el propio afiliado.
    //    SIN update, SIN delete (inmutable).
    match /reportes_sintomas/{id} {
      allow create: if esInterno()
                       || ( isSignedIn()
                            && request.resource.data.personaId == miPersonaId()
                            && request.resource.data.keys().hasOnly(['personaId','personaNombre','personaTelefono','sintomas','texto','tieneBanderaRoja','creadoEn']) );
      allow read:   if esInterno() || (isSignedIn() && resource.data.personaId == miPersonaId());
      // D-3: puente bandera roja → despacho. SOLO el operativo gestiona el pedido (el socio NO toca el estado).
      // Whitelist por acción (calca episodios) + estadoPedido con valor válido. El create del socio queda intacto.
      allow update: if esOperativo()
                       && tocadas().hasOnly(['estadoPedido','episodioId','notaGestion','gestionadoPor','gestionadoEn'])
                       && request.resource.data.get('estadoPedido','nuevo') in ['nuevo','despachado','descartado'];
    }

    // chequeos_parametros/{id}: chequeo voluntario de signos medidos del socio (Etapa 34, N3). INMUTABLE,
    // cuelga de personaId. El afiliado carga hasta 4 signos; el cliente calcula el NEWS2 parcial y lo denorm.
    // Dispara alertas por el score/redScore (el MEDICO ve el score real; el afiliado NUNCA). Atencion en
    // gestiones_contacto/{chequeoId} (mismo mecanismo).
    //  - create: el AFILIADO SOLO sobre SI MISMO (personaId == su personaId) con forma cerrada; o esInterno.
    //  - read: rol INTERNO (panel + medico por esInterno) o el propio afiliado. SIN update, SIN delete.
    match /chequeos_parametros/{id} {
      allow create: if esInterno()
                       || ( isSignedIn()
                            && request.resource.data.personaId == miPersonaId()
                            && request.resource.data.keys().hasOnly(['personaId','personaNombre','personaTelefono','fc','sis','temp','spo2','news2Score','news2Parcial','news2RedScore','news2Nivel','creadoEn']) );
      allow read:   if esInterno() || (isSignedIn() && resource.data.personaId == miPersonaId());
    }

    // Resto del datastore: cerrado para todos, salvo superadmin. (Etapa 29 — INMUTABILIDAD REAL.)
    // Las reglas de Firestore son PERMISIVAS-ONLY: un 'allow: if false' NO bloquea lo que otro match
    // permite. El write total del catch-all contradecía la inmutabilidad de auditoria/respuestas/gestiones,
    // así que se CONDICIONA (no se agregan denies decorativos). Path con variable de colección + resto=**
    // = misma cobertura que /{document=**} sobre documentos (coleccion = colección TOP-level; las 3
    // inmutables son top-level). El write del superadmin sobre esas colecciones queda vedado PARA TODOS por
    // esta vía; sus create/read legítimos ya viven en sus matches propios (create if esInterno, etc.).
    // Etapa 29b — 'usuarios' también EXCLUIDA: si no, el catch-all PUENTEABA la guarda anti auto-edición del
    // match /usuarios (permisivas-only: cualquier match que permite, permite). Toda la administración de
    // usuarios del superadmin ya vive en /usuarios (read/create/delete/update completos, con la guarda
    // self-rol/activo ahora EFECTIVA). El create/delete real lo hace la CF por Admin SDK (bypassa reglas).
    // C-1 — 'pagos' EXCLUIDA: ledger append-only de cobranza (delete: nadie, inmutable salvo anulacion logica
    // via su match). Ni el superadmin lo borra/pisa por god-mode; su create/anular legitimos viven en /pagos.
    match /{coleccion}/{resto=**} {
      allow read:  if esSuperadmin();
      allow write: if esSuperadmin()
                      && !(coleccion in ['auditoria', 'respuestas_cuestionario', 'gestiones_contacto', 'usuarios', 'reportes_sintomas', 'chequeos_parametros', 'pagos']);
    }
  }
}
