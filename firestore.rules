rules_version = '2';

// Medicar — Estructura medica.
//   Etapa 1: Auth + rol.
//   Etapa 2 (despacho + atencion): contador atomico, episodio clinico.
//   Permisos por rol (estricto + actor): cada accion atada a su rol;
//   la clinica/cierre solo la hace el medico ASIGNADO al episodio.
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // Rol del usuario actual, leido de usuarios/{uid} (su doc lo crea el seed / Admin SDK).
    function rolActual() {
      return get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.rol;
    }

    function tieneRol(roles) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/usuarios/$(request.auth.uid))
        && (rolActual() in roles);
    }

    function isAdmin() {
      return tieneRol(['admin']);
    }

    function esDespachante() {
      return tieneRol(['despachante']);
    }

    function esMedico() {
      return tieneRol(['medico']);
    }

    // Superadmin / director medico: rol maximo, poder total sin restriccion.
    function esSuperadmin() {
      return tieneRol(['superadmin']);
    }

    // Roles operativos (lectura compartida del tablero). Incluye superadmin.
    function esOperativo() {
      return tieneRol(['despachante', 'medico', 'admin', 'superadmin']);
    }

    // Roles INTERNOS: cualquier usuario autenticado cuyo rol NO sea afiliado (incluye chofer).
    // Para lectura del catalogo comercial (prestaciones/planes) por todo el personal. Fail-closed:
    // exige doc usuarios existente; un afiliado (o sin doc) queda fuera.
    function esInterno() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/usuarios/$(request.auth.uid))
        && rolActual() != 'afiliado';
    }

    // Claves que cambia este write (set de campos tocados).
    function tocadas() {
      return request.resource.data.diff(resource.data).affectedKeys();
    }

    // Permisos granulares por persona (capa del centro de mando, ademas del rol).
    // Se guardan en usuarios/{uid}.permisos = { gestionar_moviles:bool, ... }.
    //  - superadmin: SIEMPRE true (cortocircuito; nunca depende del mapa).
    //  - resto: true SOLO si el doc existe y permisos[cap] == true.
    // FAIL-CLOSED: campo permisos ausente, cap ausente, o no-true => false.
    function tienePermiso(cap) {
      return esSuperadmin()
        || ( isSignedIn()
             && exists(/databases/$(database)/documents/usuarios/$(request.auth.uid))
             && get(/databases/$(database)/documents/usuarios/$(request.auth.uid)).data.get('permisos', {}).get(cap, false) == true );
    }

    // usuarios/{uid}: cada quien lee su doc; admin lee toda la coleccion.
    // Escritura: alta/baja/cambios de rol -> solo superadmin (via panel / Admin SDK).
    // Mi perfil: cada usuario puede actualizar SOLO su propio nombre/fotoURL (nada mas).
    match /usuarios/{uid} {
      allow read:           if esSuperadmin() || (isSignedIn() && (request.auth.uid == uid || isAdmin()));
      allow create, delete: if esSuperadmin();
      allow update: if esSuperadmin()
                       || ( isSignedIn()
                            && request.auth.uid == uid
                            && tocadas().hasOnly(['nombre','fotoURL']) );
    }

    // pacientes/{id}: identidad + antecedentes (nucleo de la historia).
    // Alta y edicion: despachante o medico (ambos), o admin. Sin borrado desde cliente,
    // SALVO superadmin: lee, edita y borra sin restriccion.
    match /pacientes/{id} {
      allow read:           if esOperativo();
      allow create, update: if esOperativo();
      allow delete:         if esSuperadmin();
    }

    // episodios/{id}: la atencion, cuelga del paciente.
    // Lectura: los 3 roles operativos.
    // Escritura: diferenciada por rol y por los campos que toca cada accion.
    match /episodios/{id} {
      // Lectura: los roles operativos ven todo el tablero. Ademas, el CHOFER dueno del
      // episodio puede leer SOLO su propio episodio (choferId == su uid). No entra a
      // esOperativo: solo gana lectura puntual de lo suyo (vista "mi despacho", Bloque 3).
      allow read:   if esOperativo()
                       || (isSignedIn() && resource.data.choferId == request.auth.uid);

      // Alta (fase despacho): solo despachante. Admin tambien. Superadmin sin restriccion.
      allow create: if esSuperadmin()
                       || ((esDespachante() || isAdmin())
                           && request.resource.data.estado == 'despacho');

      // Borrado: solo superadmin (el resto, nunca desde el cliente).
      allow delete: if esSuperadmin();

      // Update: superadmin y admin sin restriccion; el resto, segun la accion.
      allow update: if esSuperadmin() || isAdmin() || (
        isSignedIn() && (
          // Asignar / reasignar recursos: solo despachante. Toca movil/medico/chofer.
          // Permitido en cualquier estado activo (incluye derivacion entre moviles
          // durante la atencion, p.ej. internacion). El nuevo medico pasa a ser el
          // asignado y es quien puede cerrar.
          (
            esDespachante()
            && tocadas().hasOnly(['movilId','movilNombre','medicoId','medicoNombre','choferId','choferNombre'])
            && resource.data.estado in ['despacho','en_camino','arribo','atencion']
          )
          // Avanzar estado: despachante o medico. Toca estado + el timestamp de esa transicion.
          // El salto despacho -> en_camino exige movil + medico ya asignados.
          // ORIGEN debe ser activo (no terminal): impide reabrir cerrado/cancelado por esta via.
          || (
            (esDespachante() || esMedico())
            && tocadas().hasOnly(['estado','transiciones'])
            && resource.data.estado in ['despacho','en_camino','arribo']
            && request.resource.data.estado in ['en_camino','arribo','atencion']
            && (
              request.resource.data.estado != 'en_camino'
              || (resource.data.movilId != null && resource.data.medicoId != null)
            )
          )
          // Chofer: avanza SU episodio. en_camino: solo estado+transiciones. arribo: ademas puede escribir el map 'arribo' (geo). Opcion B: sin medico. Requiere movil.
          || (
            request.auth.uid == resource.data.choferId
            && resource.data.movilId != null
            && (
              (
                resource.data.estado == 'despacho'
                && request.resource.data.estado == 'en_camino'
                && tocadas().hasOnly(['estado','transiciones'])
              )
              || (
                resource.data.estado == 'en_camino'
                && request.resource.data.estado == 'arribo'
                && tocadas().hasOnly(['estado','transiciones','arribo'])
              )
            )
          )
          // Clinica + cierre: solo el medico ASIGNADO a este episodio. Origen: atencion.
          // No se permite si el caso esta ofrecido (el cedente ya no lo trabaja).
          || (
            esMedico()
            && request.auth.uid == resource.data.medicoId
            && resource.data.estado == 'atencion'
            && resource.data.get('ofrecido', false) != true
            && tocadas().hasOnly(['estado','examen','desenlace','transiciones','cierres'])
            && request.resource.data.estado == 'cerrado'
          )
          // Cierre viejo por resolucion (compat): medico asignado. Origen: atencion.
          || (
            esMedico()
            && request.auth.uid == resource.data.medicoId
            && resource.data.estado == 'atencion'
            && resource.data.get('ofrecido', false) != true
            && tocadas().hasOnly(['estado','resolucion','transiciones','cierres'])
            && request.resource.data.estado == 'cerrado'
          )
          // Cancelar / anular: despachante o medico (p.ej. falsa alarma). Origen activo.
          || (
            (esDespachante() || esMedico())
            && resource.data.estado in ['despacho','en_camino','arribo','atencion']
            && tocadas().hasOnly(['estado','motivoCancelacion','transiciones'])
            && request.resource.data.estado == 'cancelado'
          )
          // Reapertura: de cerrado a atencion. Solo el medico ASIGNADO o admin.
          // Toca estado + reabierto (auditoria) + cierres (preserva el cierre previo).
          || (
            resource.data.estado == 'cerrado'
            && request.resource.data.estado == 'atencion'
            && tocadas().hasOnly(['estado','reabierto','cierres'])
            && (
              (esMedico() && request.auth.uid == resource.data.medicoId)
              || isAdmin()
            )
          )
          // Handoff - CEDER: el medico ASIGNADO ofrece su caso en atencion.
          // Marca ofrecido=true (+ registro). Sigue siendo su medicoId, pero ya no
          // puede cargar clinica/cerrar mientras este ofrecido (la regla de cierre
          // exige !ofrecido). El caso no cambia de dueno hasta que OTRO lo tome.
          || (
            esMedico()
            && request.auth.uid == resource.data.medicoId
            && resource.data.estado == 'atencion'
            && resource.data.get('ofrecido', false) != true
            && request.resource.data.get('ofrecido', false) == true
            && tocadas().hasOnly(['ofrecido','handoff'])
          )
          // Handoff - TOMAR: OTRO medico (distinto del asignado) toma un caso ofrecido.
          // Se pone a si mismo como medicoId y baja ofrecido=false (+ registro).
          // Aca SI cambia de dueno.
          || (
            esMedico()
            && resource.data.get('ofrecido', false) == true
            && resource.data.estado == 'atencion'
            && request.auth.uid != resource.data.medicoId
            && request.resource.data.medicoId == request.auth.uid
            && request.resource.data.ofrecido == false
            && tocadas().hasOnly(['medicoId','medicoNombre','ofrecido','handoff'])
          )
        )
      );
    }

    // contadores/{id}: correlativo atomico (nroIncidente).
    // Lectura/escritura dentro de la transaccion de alta (operativos). Borrado solo superadmin.
    match /contadores/{id} {
      allow read, write: if esOperativo();
      allow delete:      if esSuperadmin();
    }

    // staff_medico/{uid}: padron de medicos para asignacion (doc id = uid de Auth).
    // Solo datos de staff (nombre, activo) — sin afiliados, por eso es legible por operativos.
    // Alta/baja: admin (director medico) o superadmin. El uid sigue siendo la clave de las
    // reglas de episodios (medicoId == request.auth.uid), que no cambian.
    match /staff_medico/{uid} {
      allow read:           if esOperativo();
      allow create, delete: if isAdmin() || esSuperadmin();
      // Mi perfil: el propio médico puede actualizar SOLO su nombre en su ficha; nada mas.
      allow update: if isAdmin() || esSuperadmin()
                       || ( esMedico()
                            && request.auth.uid == uid
                            && tocadas().hasOnly(['nombre']) );
    }

    // moviles/{id}: flota. CASO DE PRUEBA de la capa de permisos granulares.
    //  - Lectura: roles operativos (todos ven la flota en el tablero).
    //  - Escritura (alta/edicion/baja): SOLO quien tenga gestionar_moviles
    //    (o superadmin, por cortocircuito en tienePermiso). Fail-closed.
    match /moviles/{id} {
      allow read:           if esOperativo();
      // Alta/baja y CRUD general de la flota: gestionar_moviles.
      allow create, delete: if esOperativo() && tienePermiso('gestionar_moviles');
      allow update: if esOperativo() && (
        // (a) CRUD general (editar campos del móvil): gestionar_moviles.
        tienePermiso('gestionar_moviles')
        // (b) DESPACHO: ocupar/liberar el móvil al asignar/reasignar desde el episodio.
        //     SOLO toca estado + episodioActivoId + actualizadoEn, y SOLO la transición
        //     disponible<->ocupado. Requiere despachar_episodios. Fail-closed.
        || (
          tienePermiso('despachar_episodios')
          && tocadas().hasOnly(['estado','episodioActivoId','actualizadoEn'])
          && resource.data.estado in ['disponible','ocupado']
          && request.resource.data.estado in ['disponible','ocupado']
        )
      );
    }

    // tipos_movil/{id}: catálogo de tipos de móvil (UTI, Traslado, ...). Mismo criterio que moviles:
    // lo ve cualquier operativo (para resolver el nombre del tipo en la flota), lo gestiona quien
    // tenga gestionar_moviles. Baja lógica vía campo activo (no se borra desde acá salvo superadmin
    // por el catch-all). Fail-closed igual que moviles.
    match /tipos_movil/{id} {
      allow read:                  if esOperativo();
      allow create, update, delete: if esOperativo() && tienePermiso('gestionar_moviles');
    }

    // guardias/{id}: cronograma de tripulacion (Bloque 1). Una guardia = UNA persona (chofer o medico)
    // en una ventana horaria, en un movil ('activa') o sin movil ('pasiva' = backup / auto propio).
    //  - Lectura: operativos (el chofer NO lee guardias todavia; eso es su propio bloque).
    //  - Escritura: gestionar_guardias. La regla valida PERMISO + FORMA + COHERENCIA LOCAL (mira solo
    //    el doc, sin queries). Los SOLAPES y medico-sin-chofer se validan en CLIENTE: las reglas no
    //    pueden hacer queries de rango entre docs.
    function guardiaFormaOK(d) {
      return d.rol in ['chofer','medico']
        && d.modalidad in ['activa','pasiva']
        && d.estado in ['programada','activa','cerrada']
        && (
             (d.modalidad == 'activa' && d.get('movilId', null) != null)
          || (d.modalidad == 'pasiva' && d.get('movilId', null) == null)
        );
    }
    match /guardias/{id} {
      allow read:           if esOperativo();
      allow create, update: if esOperativo()
                               && tienePermiso('gestionar_guardias')
                               && guardiaFormaOK(request.resource.data);
      allow delete:         if esOperativo() && tienePermiso('gestionar_guardias');
    }

    // prestaciones/{id}: catalogo base de prestaciones (Emergencias, Urgencias, ...). Estructura 3 (Admin).
    //  - Lectura: cualquier rol INTERNO (no afiliado), incluido chofer — el personal lo consulta.
    //  - Escritura (alta/edicion; baja LOGICA via campo 'activo'): admin/superadmin o configurar_sistema.
    //    (tienePermiso ya cortocircuita superadmin a true.) Fail-closed.
    //  - Sin delete desde la app (baja logica). Superadmin conserva borrado por el catch-all.
    match /prestaciones/{id} {
      allow read:           if esInterno();
      allow create, update: if isAdmin() || tienePermiso('configurar_sistema');
    }

    // planes/{id}: catalogo comercial de planes + mapa coberturas{prestacionId:bool}. Estructura 3 (Admin).
    //  - Lectura: rol INTERNO (un afiliado podria leer su plan a futuro; por ahora restringido a internos).
    //  - Escritura: admin/superadmin o configurar_sistema. Baja logica via 'activo', sin delete desde la app.
    match /planes/{id} {
      allow read:           if esInterno();
      allow create, update: if isAdmin() || tienePermiso('configurar_sistema');
    }

    // personas/{id}: identidad del nucleo (Estructura 3, Admin). Si proviene de un paciente, id == pacienteId
    // (los episodios siguen apuntando por pacienteId, sin tocarse). Lleva los antecedentes CLINICOS.
    //  - Lectura: cualquier rol INTERNO (no afiliado).
    //  - Escritura (alta/edicion): admin/superadmin o gestionar_afiliados. Sin delete desde la app.
    match /personas/{id} {
      allow read:           if esInterno();
      allow create, update: if isAdmin() || tienePermiso('gestionar_afiliados');
    }

    // socios/{id}: padron de afiliados (Estructura 3, Admin). Apunta a personas via personaId; planId a planes.
    //  - Lectura: rol INTERNO.
    //  - Escritura: admin/superadmin o gestionar_afiliados. Baja LOGICA via 'activo', sin delete desde la app.
    match /socios/{id} {
      allow read:           if esInterno();
      allow create, update: if isAdmin() || tienePermiso('gestionar_afiliados');
    }

    // staff/{id}: padron laboral del personal (Estructura 3, Bloque 3). id == uid del usuario; apunta a
    // personas via personaId (== id). rol laboral medico|chofer|despachante|administrativo + matricula.
    //  - Lectura: rol INTERNO.
    //  - Escritura (alta/edicion): admin/superadmin o gestionar_personal. Baja LOGICA via 'activo', sin
    //    delete desde la app. NO altera las reglas de usuarios (cuentas) ni staff_medico (intactas).
    match /staff/{id} {
      allow read:           if esInterno();
      allow create, update: if isAdmin() || tienePermiso('gestionar_personal');
    }

    // tarifas/{id}: catalogo de tarifas de facturacion (Estructura 1, Contable). tipoCalculo fija|por_km,
    // precioBase, valorPorKm. Base para los motores de facturacion futuros.
    //  - Lectura: rol INTERNO (no afiliado).
    //  - Escritura (alta/edicion; baja LOGICA via 'activo'): admin/superadmin o configurar_sistema.
    //    Sin delete desde la app. Superadmin conserva borrado por el catch-all.
    match /tarifas/{id} {
      allow read:           if esInterno();
      allow create, update: if isAdmin() || tienePermiso('configurar_sistema');
    }

    // cargos/{id}: cargos de facturacion generados por episodio (Estructura 1, Contable). DESVIO DELIBERADO
    // del patron: es DATA FINANCIERA, NO se abre a todo el personal interno.
    //  - Lectura Y escritura: SOLO admin/superadmin o configurar_sistema (NO esInterno).
    //  - Anulacion LOGICA via estado:'anulado'; NUNCA delete desde la app.
    match /cargos/{id} {
      allow read:           if isAdmin() || tienePermiso('configurar_sistema');
      allow create, update: if isAdmin() || tienePermiso('configurar_sistema');
    }

    // abonos/{id}: cuotas mensuales por socio (Estructura 1, Contable). MISMO desvio financiero que /cargos:
    // DATA FINANCIERA, no se abre a todo el personal interno.
    //  - Lectura Y escritura: SOLO admin/superadmin o configurar_sistema (NO esInterno).
    //  - Anulacion LOGICA via estado:'anulado'; NUNCA delete desde la app.
    match /abonos/{id} {
      allow read:           if isAdmin() || tienePermiso('configurar_sistema');
      allow create, update: if isAdmin() || tienePermiso('configurar_sistema');
    }

    // facturas/{id}: cierre de Contable (Estructura 1). Agrupa abono + cargos por persona (items congelados).
    // MISMO desvio financiero que /cargos y /abonos: DATA FINANCIERA.
    //  - Lectura Y escritura: SOLO admin/superadmin o configurar_sistema (NO esInterno).
    //  - Anulacion LOGICA via estado:'anulada' (libera el facturaId de los items); NUNCA delete desde la app.
    match /facturas/{id} {
      allow read:           if isAdmin() || tienePermiso('configurar_sistema');
      allow create, update: if isAdmin() || tienePermiso('configurar_sistema');
    }

    // leads/{id}: prospectos de captacion (Estructura 2, Marketing — Bloque 1). Datos personales de
    // interesados: NO se abre a todo el personal interno.
    //  - Lectura Y escritura: SOLO admin/superadmin o gestionar_afiliados (quien convierte da altas).
    //  - Descarte LOGICO via estado:'descartado'; conversion via estado:'convertido'; NUNCA delete desde la app.
    match /leads/{id} {
      allow read:           if isAdmin() || tienePermiso('gestionar_afiliados');
      allow create, update: if isAdmin() || tienePermiso('gestionar_afiliados');
    }

    // campanas/{id}: campanas de captacion (Estructura 2, Marketing — Bloque 3). Datos de marketing.
    //  - Lectura Y escritura: SOLO admin/superadmin o gestionar_afiliados (mismo gateo que leads).
    //  - Baja LOGICA via 'activo'; NUNCA delete desde la app.
    match /campanas/{id} {
      allow read:           if isAdmin() || tienePermiso('gestionar_afiliados');
      allow create, update: if isAdmin() || tienePermiso('gestionar_afiliados');
    }

    // Resto del datastore: cerrado para todos, salvo superadmin (poder total).
    match /{document=**} {
      allow read, write: if esSuperadmin();
    }
  }
}
